# Required: used to encrypt saved Postgres passwords at rest.
# Generate one with: openssl rand -hex 32
PNO_MASTER_KEY=change-me-to-a-long-random-secret

# Optional: shared password for the web UI. When unset, auth is disabled (local dev).
# PNO_AUTH_PASSWORD=change-me-to-a-strong-password

# Optional: where the local SQLite metadata database is stored
PNO_DATA_DIR=./data
